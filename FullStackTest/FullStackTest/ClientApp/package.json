{
  "name": "fullstacktest",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node aspnetcore-https",
    "start": "run-script-os",
    "start:windows": "ng serve --port 44439 --ssl --ssl-cert %APPDATA%\\ASP.NET\\https\\%npm_package_name%.pem --ssl-key %APPDATA%\\ASP.NET\\https\\%npm_package_name%.key",
    "start:default": "ng serve --port 44439 --ssl --ssl-cert $HOME/.aspnet/https/${npm_package_name}.pem --ssl-key $HOME/.aspnet/https/${npm_package_name}.key",
    "build": "ng build",
    "build:ssr": "ng run FullStackTest:server:dev",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~19.1.6",
    "@angular/common": "~19.1.6",
    "@angular/compiler": "~19.1.6",
    "@angular/core": "~19.1.6",
    "@angular/forms": "~19.1.6",
    "@angular/platform-browser": "~19.1.6",
    "@angular/platform-browser-dynamic": "~19.1.6",
    "@angular/platform-server": "~19.1.6",
    "@angular/router": "~19.1.6",
    "bootstrap": "5.3",
    "bootstrap-icons": "^1.13.1",
    "run-script-os": "^1.1.6",
    "rxjs": "~6.6.0",
    "tslib": "^2.1.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~19.1.7",
    "@angular/cli": "~19.1.7",
    "@angular/compiler-cli": "~19.1.6",
    "@types/bootstrap": "^5.2.10",
    "@types/jasmine": "~3.6.0",
    "@types/jasminewd2": "~2.0.8",
    "@types/node": "^12.11.1",
    "angular-eslint": "21.0.1",
    "eslint": "^9.39.1",
    "jasmine-core": "~3.8.0",
    "karma": "~6.3.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.0.3",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "^1.5.0",
    "typescript": "~5.7.3",
    "typescript-eslint": "8.46.4"
  }
}